// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {},
  "language_models": {
    "opencode": {
      "show_free_models": true,
      "show_zen_models": false,
    },
  },
  "project_panel": {
    "dock": "left",
    "git_status": true,
  },
  "tabs": {
    "git_status": true,
  },
  "outline_panel": {
    "dock": "right",
    "button": false,
  },
  "when_closing_with_no_tabs": "platform_default",
  "edit_predictions": {
    "allow_data_collection": "no",
    "open_ai_compatible_api": {
      "prompt_format": "deepseek_coder",
      "model": "deepseek-v4-flash",
      "api_url": "https://opencode.ai/zen/go/v1/chat/completions",
    },
    "provider": "copilot",
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "terminal": {
    "flexible": false,
    "cursor_shape": "bar",
    "dock": "right",
    "option_as_meta": true,
  },
  "git_panel": {
    "show_count_badge": false,
    "file_icons": true,
    "sort_by_path": false,
    "collapse_untracked_diff": false,
    "status_style": "label_color",
    "dock": "left",
    "tree_view": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "buffer_font_family": "SauceCodePro Nerd Font",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "icon_theme": "Symbols Icon Theme",
  "ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": "Ayu Dark",
  "agent": {
    "inline_assistant_model": {
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
      "enable_thinking": false,
    },
    "sidebar_side": "left",
    "dock": "right",
    "button": true,
    "default_model": {
      "effort": "high",
      "provider": "opencode",
      "model": "go/deepseek-v4-pro",
      "enable_thinking": true,
    },
    "commit_message_model": {
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
    },
  },
}
