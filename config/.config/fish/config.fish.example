# --- 1. Interactive Session Settings ---
if status is-interactive
    function fish_greeting
        fish_logo
        echo ''
    end

    # Theme Settings (Bobthefish / Oh My Fish)
    set -g theme_color_scheme dracula
    set -g theme_display_date no
    set -g theme_display_cmd_duration yes
    set -g theme_powerline_fonts no
    set -g theme_nerd_fonts yes
    set -g theme_display_git_master_branch yes
    set -g theme_display_user ssh
    set -g theme_display_hostname ssh
    set -g theme_title_display_user no
    set -g theme_title_display_process yes
    set -g theme_title_display_path yes

    # FZF
    set -U FZF_LEGACY_KEYBINDINGS 0

    # Abbreviations
    abbr -a ccm npx ccmanager@latest
end

# --- 2. Environment Variables ---
# Homebrew Cask
set -gx HOMEBREW_CASK_OPTS --appdir=/Applications
set -gx HOMEBREW_GITHUB_API_TOKEN xxxxx

# Android SDK & Java
set -gx ANDROID_HOME $HOME/Library/Android/sdk
set -gx JAVA_HOME "/Applications/Android Studio.app/Contents/jbr/Contents/Home"

# PostgreSQL
set -gx PGDATA /usr/local/var/postgres

# Claude Code
set -gx DISABLE_AUTOUPDATER 1

# --- 3. PATH Configuration (Homebrew & Tools) ---
# Homebrew
if test -d /opt/homebrew
    eval (/opt/homebrew/bin/brew shellenv)
end

# Legacy support (Intel mac binaries running on Rosetta 2 etc)
fish_add_path /usr/local/sbin

# Android Tools
fish_add_path $JAVA_HOME/bin
fish_add_path $HOME/Library/Android/sdk/platform-tools

# uv
fish_add_path "$HOME/.local/bin"

# --- 4. Version Manager (Mise) ---
mise activate --shims fish | source
