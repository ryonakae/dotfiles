// UI
theme "ayu_dark"
simplified_ui true
pane_frames false

// 操作
default_mode "locked"

// 通知・表示
show_startup_tips false
show_release_notes false

// キーバインド
keybinds {
    locked {
        bind "Alt h" { MoveFocusOrTab "Left"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
        bind "Alt l" { MoveFocusOrTab "Right"; }
        bind "Alt f" { ToggleFloatingPanes; }
        bind "Alt p" { SwitchToMode "Pane"; }
        bind "Alt t" { SwitchToMode "Tab"; }
        bind "Alt o" { SwitchToMode "Session"; }
        bind "Alt n" { SwitchToMode "Resize"; }
        bind "Alt a" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/zam.wasm" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "Alt Shift a" {
            Run \
                "sh" \
                "-lc" \
                "ZAM_SIDEBAR_WIDTH=20% ZAM_SIDEBAR_IN_PLACE=1 exec \"$HOME/.config/zellij/scripts/open-zam-sidebar.sh\"" {
                name "zam-sidebar-launcher"
                close_on_exit true
                start_suspended false
                direction "Right"
            }
        }
    }
    shared_except "locked" {
        bind "Ctrl Alt q" { Quit; }
    }
    shared {
        bind "Alt a" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/zam.wasm" {
                floating true
                move_to_focused_tab true
            }
        }
        bind "Alt Shift a" {
            Run \
                "sh" \
                "-lc" \
                "ZAM_SIDEBAR_WIDTH=20% ZAM_SIDEBAR_IN_PLACE=1 exec \"$HOME/.config/zellij/scripts/open-zam-sidebar.sh\"" {
                name "zam-sidebar-launcher"
                close_on_exit true
                start_suspended false
                direction "Right"
            }
        }
    }
}
