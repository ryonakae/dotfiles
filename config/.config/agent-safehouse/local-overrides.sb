;; Agent Safehouse のローカルオーバーライド。
;; 生成ポリシーの後に読み込まれるため、ここでの deny/allow が最終的な優先権を持つ。
;; 通常の共有アクセスには --add-dirs-ro/--add-dirs を使い、ホスト固有のルールをここに書く。

;; allow 済みパス（workdir, --add-dirs 列挙先, /tmp 等）内の機密ファイルをファイル名パターンで deny する。
;; ~/.ssh/id_* 等は Safehouse の deny default で保護済みだが、workdir にコピーされた
;; 機密ファイルはカバーされないため、ここで包括的に塞ぐ。
;;
;; スコープの使い分け:
;;   .* (全パス)   — システムパスに同名ファイルが存在しないパターン
;;   HOME_DIR 限定 — /opt/homebrew/etc 等のシステム SSL 証明書と衝突するパターン
(deny file-read* file-write*
    ;; 環境変数 / 設定ファイル
    (regex #".*/\.env$")
    (regex #".*/\.env\.local$")
    (regex #".*/\.env\.development$")
    (regex #".*/\.env\.development\.local$")
    (regex #".*/\.env\.preview$")
    (regex #".*/\.env\.preview\.local$")
    (regex #".*/\.env\.staging$")
    (regex #".*/\.env\.staging\.local$")
    (regex #".*/\.env\.production$")
    (regex #".*/\.env\.production\.local$")
    (regex #".*/\.env\.test$")
    (regex #".*/\.env\.test\.local$")
    (regex #".*/\.envrc$")

    ;; クラウド / サービス認証情報
    (regex #".*/credentials\.json$")
    (regex #".*/service-account[^/]*\.json$")
    (regex #".*/[^/]*-credentials\.json$")
    (regex #".*/firebase-adminsdk[^/]*\.json$")

    ;; SSH 秘密鍵（workdir/tmp にコピーされたものを想定。~/.ssh は deny default で保護済み）
    (regex #".*/id_rsa$")
    (regex #".*/id_ed25519$")
    (regex #".*/id_ecdsa$")
    (regex #".*/id_dsa$")

    ;; シークレットディレクトリ
    (regex #".*/secrets(/.*)?$")
    (regex #".*/\.secrets(/.*)?$")

    ;; 証明書 / キーストア（HOME_DIR 限定: システム SSL 証明書との衝突を回避）
    ;; certifi の CA バンドルは秘密鍵ではなく HTTPS 通信に必須なため除外
    (require-all
        (regex (string-append "^" HOME_DIR "/.*\\.pem$"))
        (require-not (regex #".*/certifi/cacert\.pem$"))
    )
    (regex (string-append "^" HOME_DIR "/.*\\.p8$"))
    (regex (string-append "^" HOME_DIR "/.*\\.p12$"))
    (regex (string-append "^" HOME_DIR "/.*\\.key$"))
    (regex (string-append "^" HOME_DIR "/.*\\.jks$"))
    (regex (string-append "^" HOME_DIR "/.*\\.keystore$"))
)

;; サードパーティ依存ディレクトリ配下に紛れる .env / 鍵 / pem は agent 個人の機密ではなく、
;; git clone / ビルドで読み書きが必要。上記の汎用 deny を後勝ち allow で例外化する。
;; これが無いと vendor/libghostty-vt/.envrc の checkout が deny されて clone が失敗する。
(allow file-read* file-write*
    (regex #".*/(vendor|node_modules|third_party)/.*/\.env[^/]*$")
    (regex #".*/(vendor|node_modules|third_party)/.*/\.envrc$")
    (regex #".*/(vendor|node_modules|third_party)/.*/id_(rsa|dsa|ecdsa|ed25519)$")
    (regex #".*/(vendor|node_modules|third_party)/.*\.pem$")
    (regex #".*/(vendor|node_modules|third_party)/.*\.p(8|12)$")
    (regex #".*/(vendor|node_modules|third_party)/.*\.(key|jks|keystore)$")
    ;; Cargo registry の test fixture (libnghttp2-sys 等)
    (regex (string-append "^" HOME_DIR "/\\.cargo/registry/.*\\.pem$"))
)

;; Flutter SDK / pub cache / analysis server / Android SDK manager の状態は同じワークフローで必要になる。
;; いずれも wrapper の --add-dirs top-level 列挙の外なので、ここで明示 allow する。
(allow file-read* file-write*
    (home-subpath "/.local/share/mise/installs/flutter")
    (home-subpath "/.pub-cache")
    (home-subpath "/.dart-tool")
    (home-subpath "/.dartServer")
    (home-subpath "/.android/cache")
)

;; --enable=xcode の標準プロファイルは macOS 26 / Xcode 26 系の Simulator runtime に
;; 必要な mach service / fsctl をカバーしていないため、ここで補う。
;; これが無いと simctl が "liblaunch_sim.dylib could not be opened" /
;; "iOS-26-X Unavailable" で booted な Simulator を認識できない。
(allow mach-lookup
    (global-name "com.apple.CoreSimulator.simdiskimaged")
    (global-name "com.apple.CoreSimulator.SimLaunchHost-arm64")
)

;; DMG / cryptex マウントの読み書きで simctl が発行する fsctl ioctl。
(allow system-fsctl
    (fsctl-command (_IO "J" 32))
)

;; config.fish にマシンローカルの機密情報が含まれているため、
;; shell-init が有効化された場合でも読み書きを拒否する。
(deny file-read* file-write*
    (home-literal "/.config/fish/config.fish")
    (home-literal "/dotfiles/config/.config/fish/config.fish")
)

;; ホスト上の各種クレデンシャル。wide-read で / 全 read 開放しているため、
;; 列挙ベースで個別に塞ぐ。~/.ssh は safehouse default で deny 済みなので含めない。
(deny file-read* file-write*
    (home-subpath "/.gnupg")
    (home-literal "/.aws/credentials")
    (home-literal "/.netrc")
    (home-literal "/.git-credentials")
    (home-literal "/.kube/config")
)

;; ~/.hermes は Hermes Agent の workdir かつ信頼境界。
;; Agent が自己改善で .env / hooks / cron / automations / skills を書き換える前提のため、
;; 上記の汎用 deny（.env / secrets / credentials.json 等）を後勝ちで貫通させる。
;; 信頼境界は ~/.hermes の内側に閉じる前提。
(allow file-read* file-write*
    (home-subpath "/.hermes")
)

;; terminal-notifier (macOS通知) が必要とする Mach サービスを許可。
;; macos-gui では hiservices 等は許可されるが、UserNotifications フレームワーク
;; が使う usernoted デーモンへの接続は含まれていないため、ここで補足する。
(allow mach-lookup
    (global-name "com.apple.usernoted.client")
    (global-name "com.apple.usernoted.daemon_client")
    (global-name "com.apple.usernotifications.usernotificationservice")
)
