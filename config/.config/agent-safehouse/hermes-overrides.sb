;; Hermes Agent 専用オーバーライド。
;; gateway で自律動作するため、不要なディレクトリへのアクセスを遮断する。

;; パーソナルディレクトリ — Hermes Agent が触る理由がない
(deny file-read* file-write*
    (home-subpath "/Desktop")
    (home-subpath "/Downloads")
    (home-subpath "/Documents")
    (home-subpath "/Pictures")
    (home-subpath "/Music")
    (home-subpath "/Movies")
)

;; ~/Library — Hermes Agent が触る理由がない
(deny file-read* file-write*
    (home-subpath "/Library")
)

;; 他エージェントの設定 — 参照のみ許可、書き換えは禁止
(deny file-write*
    (home-subpath "/.claude")
    (home-subpath "/.codex")
    (home-subpath "/.gemini")
)

;; local-overrides.sb で一律 deny された Hermes Agent 固有パスを再許可
(allow file-read*
    (home-literal "/.hermes/.env")
    (home-subpath "/.hermes/secrets")
)

;; Google Workspace CLI の credential store (readonly スコープ専用)。
;; gws が credentials.json / .encryption_key 等を書き込むため、
;; local-overrides.sb の機密パターン deny を上書きして rw を再付与する。
(allow file-read* file-write*
    (home-subpath "/.hermes/gws")
)
