;; Hermes Agent 専用オーバーライド。
;; gateway で自律動作するため、不要なディレクトリへのアクセスを遮断する。

;; パーソナルディレクトリ — Hermes Agent が触る理由がない
(deny file-read* file-write*
    (home-subpath "/Desktop")
    (home-subpath "/Downloads")
    (home-subpath "/Documents")
    (home-subpath "/Pictures")
    (home-subpath "/Music")
    (home-subpath "/Movies")
)

;; ~/Library — 既定で全遮断し、必要なサブパスだけ後勝ちで read を再許可する
(deny file-read* file-write*
    (home-subpath "/Library")
)

;; CleanShot のスクリーンショット添付、macos-gui (CFPrefs/通知センター) が読む最小領域
(allow file-read*
    (home-subpath "/Library/Application Support/CleanShot/media")
    (home-literal "/Library/Preferences/.GlobalPreferences.plist")
    (home-subpath "/Library/Preferences/ByHost")
    (home-literal "/Library/LaunchAgents/ai.hermes.gateway.plist")
)

;; mise がツール検出キャッシュを書き込むため rw を再許可（WARN ノイズ抑制）
(allow file-read* file-write*
    (home-subpath "/Library/Caches/mise")
)

;; 他エージェントの設定・認証トークンは --enable=all-agents 側で rw 許可される。
;; cross-agent 実行（Hermes が claude / codex / gemini を呼ぶ等）で credential が
;; 必要になるため、ここでは追加の deny を置かない。

;; Hermes Agent は自己改善で hooks/cron/automations/skills を書き換える設計のため、
;; ~/.hermes 配下は local-overrides.sb の汎用 deny（.env / secrets / credentials.json 等）を
;; 上書きして rw を全面許可する。信頼境界は ~/.hermes の内側に閉じる前提。
(allow file-read* file-write*
    (home-subpath "/.hermes")
)
