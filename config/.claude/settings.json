{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(gh pr view *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git status *)",
      "WebFetch",
      "WebSearch",
      "mcp__context7",
      "mcp__gemini-cli",
      "Skill(ask-gemini)",
      "Skill(auto-code-review)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development*)",
      "Read(.env.preview*)",
      "Read(.env.staging*)",
      "Read(.env.production*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "出力はJSONのみ。説明文やマークダウン記法は禁止。\n\n入力: $ARGUMENTS\n\n判定ルール:\n- stop_hook_active が true → {\"ok\": true}\n- last_assistant_message がコード実装の完了報告（コードファイル・依存関係・スクリプト・設定ファイルの変更）→ {\"ok\": false, \"reason\": \"doc-updater サブエージェントを実行し、変更ファイル一覧を渡す。セッション中の失敗・修正から防止策があればそれも含める\"}\n- それ以外（質問回答・調査・計画・ドキュメントのみ・テストのみ・会話） → {\"ok\": true}"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "language": "日本語",
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": false
}
