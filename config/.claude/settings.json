{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(gh pr view *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git status *)",
      "WebFetch",
      "WebSearch",
      "mcp__context7",
      "mcp__gemini-cli",
      "Skill(ask-gemini)",
      "Skill(auto-code-review)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development*)",
      "Read(.env.preview*)",
      "Read(.env.staging*)",
      "Read(.env.production*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Claudeの直前の応答が、コードの実装・修正・リファクタリングを完了した報告かどうか判定してください。以下はyesではありません: 質問への回答、計画や設計の提示、調査報告、ドキュメントのみの変更、テストのみの実行、会話的なやり取り。コードファイル（.ts, .tsx, .js, .jsx, .py, .swift, .kt 等）の作成・編集を伴う実装作業が完了してユーザーに報告している場合のみyesとしてください。"
          },
          {
            "type": "command",
            "command": "if [ -z \"$DOC_UPDATER_RUNNING\" ]; then export DOC_UPDATER_RUNNING=1; claude --agent doc-updater -p 'Claude Codeによる実装が完了しました。git diff HEAD で変更内容を確認し、必要に応じてドキュメントを更新してください。' & fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "language": "日本語",
  "model": "opusplan"
}
