{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(gh pr view *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git status *)",
      "WebFetch",
      "WebSearch",
      "mcp__context7",
      "Skill(ask-gemini)",
      "Skill(ask-codex)",
      "Skill(auto-code-review)",
      "Skill(commit-push)",
      "mcp__pencil"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development*)",
      "Read(.env.preview*)",
      "Read(.env.staging*)",
      "Read(.env.production*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Bash(sudo *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "timeout": 180,
            "model": "claude-sonnet-4-6"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "language": "日本語",
  "spinnerTipsEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
